# PostgreSQL — devcontainer db service (already running, no changes needed)
DATABASE_URL=postgresql://postgres:postgres@db:5432/jarvis

# Google Gemini
# Get an API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
# Optional — comma-separated list of Gemini model names in priority order.
# On a rate-limit error (HTTP 429) the next model is tried automatically.
# Defaults to: gemini-2.5-flash-lite,gemini-2.5-flash
#GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash

# GitHub
# Personal Access Token with: contents:write, actions:write
# https://github.com/settings/tokens/new
GITHUB_TOKEN=
# Organisation or user name that owns the target repo
GITHUB_REPO_OWNER=
# Repository name (e.g. daily-haskell)
GITHUB_REPO_NAME=
# Optional — defaults to main
#GITHUB_BRANCH=main
# Path inside the repo where Hugo posts live — defaults to content/posts
#GITHUB_POSTS_PATH=content/posts
# Workflow filename to dispatch the deploy — defaults to deploy.yml
#GITHUB_WORKFLOW_ID=deploy.yml

# Discord
# Create a bot at https://discord.com/developers/applications
#   → Bot → Reset Token (copy the value below)
#   → Bot → enable "Message Content Intent" and "Server Members Intent"
#   → OAuth2 → URL generator: scopes=bot,
#     permissions: Send Messages, Read Message History, Add Reactions,
#                  Create Public Threads, Use Slash Commands
DISCORD_BOT_TOKEN=
# Right-click your server → Copy Server ID  (enable Developer Mode first)
DISCORD_GUILD_ID=
# Right-click the review forum channel → Copy Channel ID
DISCORD_CHANNEL_ID=
# Right-click the text channel used for slash commands and bot notices → Copy Channel ID
DISCORD_INTERACTION_CHANNEL_ID=

# Scheduler
# Each worker runs on its own independent schedule.

# How often to discover new content via Gemini. Default: 86400 (24 h).
#DISCOVERY_INTERVAL_SECS=86400

# How often to pick a pending item and generate a draft. Default: 43200 (12 h).
# Set this shorter than DISCOVERY_INTERVAL_SECS so drafts are queued promptly.
#DRAFT_INTERVAL_SECS=43200
